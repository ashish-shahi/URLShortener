<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - URL Shortener</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="page-wrapper">
        <div class="auth-card">
            <h2>Welcome back</h2>
            <p class="subtitle">Log in to manage your short links</p>

            <% if (typeof error !== 'undefined' && error) { %>
                <p class="error-msg"><%= error %></p>
            <% } %>

            <form method="POST" action="/login">
                <label for="email">Email</label>
                <input type="email" id="email" name="user_email" placeholder="name@company.com" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="user_pass" placeholder="Enter your password" required>

                <button type="submit">Log in</button>
            </form>

            <p class="footer-text">
                Don't have an account? <a href="/register">Register</a>
            </p>
        </div>
    </div>
</body>
</html>